{
  "compilerOptions": {
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "react"]
  },
  "include": [
    "spikes/**/*.ts",
    "spikes/**/*.tsx",
    "tests/**/*.ts",
    "tools/**/*.mjs",
    "tools/**/*.mts"
  ]
}
