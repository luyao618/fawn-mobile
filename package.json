{
  "name": "for-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "workspaces": [
    "spikes/model-transport"
  ],
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=10.9.3"
  },
  "scripts": {
    "slice0": "node tools/run-slice0.mjs",
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "mock:provider": "tsx tools/start-mock-provider.mts",
    "test": "jest",
    "test:app": "jest --runInBand",
    "test:node": "tsx --test tests/unit/model/*.test.ts tests/unit/backup/*.test.ts tests/unit/tooling/*.test.ts spikes/sqlite-fts/*.test.ts",
    "test:g017": "tsx --test tests/unit/model/*.test.ts tests/unit/tooling/*.test.ts",
    "test:knowledge": "python3 -m unittest discover -s tools/knowledge/tests -p 'test_*.py'",
    "test:fts": "python3 spikes/sqlite-fts/benchmark.py --all",
    "test:dependencies": "node tools/check-app-dependencies.mjs --dependencies",
    "test:licenses:slice0": "node tools/check-licenses.mjs",
    "test:licenses:app": "node tools/check-app-dependencies.mjs --licenses",
    "test:licenses": "npm run test:licenses:slice0 && npm run test:licenses:app",
    "test:audit:slice0": "node tools/check-audit.mjs",
    "test:audit:app": "node tools/check-app-audit.mjs",
    "test:audit": "npm run test:audit:slice0 && npm run test:audit:app",
    "test:config": "node tools/check-app-config.mjs",
    "test:fault-scaffold": "bash scripts/e2e/run-fault-matrix.sh all --dry-run",
    "test:e2e:android": "maestro test e2e/maestro/shell-smoke.yaml",
    "test:e2e:ios": "maestro test e2e/maestro/shell-smoke.yaml",
    "test:e2e:android:faults": "bash scripts/e2e/run-fault-matrix.sh android",
    "test:e2e:ios:faults": "bash scripts/e2e/run-fault-matrix.sh ios",
    "typecheck": "node tools/run-typecheck.mjs",
    "lint": "eslint eslint.config.js 'App{,.android,.ios,.native}.{js,jsx,mjs,cjs,ts,tsx,mts,cts}' app.config.ts 'index{,.android,.ios,.native}.{js,jsx,mjs,cjs,ts,tsx,mts,cts}' metro.config.cjs src tests/app tests/unit/tooling tests/setup.ts tools/check-licenses.mjs tools/check-fault-bundles.mjs tools/check-app-dependencies.mjs tools/check-app-audit.mjs tools/check-app-config.mjs tools/check-native-schemes.mjs tools/collect-ci-evidence.mjs tools/clean-generated.mjs --max-warnings=0",
    "expo:doctor": "expo-doctor --verbose",
    "expo:doctor:g017": "node tools/run-expo-doctor-isolated.mjs",
    "g017:install": "cd spikes/model-transport && npm ci --workspaces=false",
    "g017:export:android": "npm --prefix spikes/model-transport run export:android",
    "g017:export:ios": "npm --prefix spikes/model-transport run export:ios",
    "spike:ios": "npm --workspace @fawn-mobile/slice0-device-proof run ios",
    "spike:android": "npm --workspace @fawn-mobile/slice0-device-proof run android",
    "prebuild:android:production": "EXPO_PUBLIC_FOR_MOBILE_BUILD_FLAVOR=production expo prebuild --clean --platform android --no-install",
    "prebuild:android:e2e": "EXPO_PUBLIC_FOR_MOBILE_BUILD_FLAVOR=e2e expo prebuild --clean --platform android --no-install",
    "prebuild:ios:production": "EXPO_PUBLIC_FOR_MOBILE_BUILD_FLAVOR=production expo prebuild --clean --platform ios --no-install",
    "prebuild:ios:e2e": "EXPO_PUBLIC_FOR_MOBILE_BUILD_FLAVOR=e2e expo prebuild --clean --platform ios --no-install",
    "clean:generated": "node tools/clean-generated.mjs",
    "test:fault-bundles": "node tools/check-fault-bundles.mjs"
  },
  "dependencies": {
    "@react-native-vector-icons/lucide": "13.1.2",
    "@react-navigation/bottom-tabs": "7.18.8",
    "@react-navigation/native": "7.3.8",
    "expo": "57.0.4",
    "expo-dev-client": "57.0.5",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "24.3.0",
    "@types/react": "19.2.14",
    "eslint": "9.39.5",
    "eslint-config-expo": "57.0.0",
    "expo-doctor": "1.20.0",
    "jest": "29.7.0",
    "jest-expo": "57.0.1",
    "react-test-renderer": "19.2.3",
    "tsx": "4.20.5",
    "typescript": "6.0.3"
  }
}
