    "validate:device-evidence": "node deviceEvidenceValidator.mjs",
    "check:licenses": "node licenseCheck.mjs"
  },
  "dependencies": {
    "expo": "57.0.4",
    "expo-build-properties": "57.0.3",
    "expo-crypto": "57.0.0",
