    "react-native": "0.86.0",
    "react-native-nitro-modules": "0.36.1",
    "react-native-quick-base64": "3.0.1",
    "react-native-quick-crypto": "1.1.6"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "@types/react": "19.2.14",
    "expo-doctor": "1.20.0",
    "tsx": "4.20.5",
    "typescript": "6.0.3"
  }
}
