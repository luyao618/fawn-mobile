{
  "name": "@fawn-mobile/g016-backup-crypto",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android --device fawn_pixel_api33",
    "ios": "expo run:ios",
    "test": "node --import tsx --test ../../tests/unit/backup/fmbk-and-recovery.test.ts ../../tests/unit/backup/g016-proof-and-validator.test.ts",
