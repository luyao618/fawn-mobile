{
  "name": "@fawn-mobile/g015-sqlite-fts",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "fixtures:generate": "node scripts/generate-fixtures.mjs",
    "fixtures:check": "node scripts/generate-fixtures.mjs --check",
    "postinstall": "npm run fixtures:generate",
    "start": "expo start",
    "preandroid": "npm run fixtures:check",
    "android": "expo run:android --device fawn_pixel_api33",
    "preexport": "npm run fixtures:check",
    "export": "expo export --platform android",
    "pretest": "npm run fixtures:check",
    "test": "tsx --test scoring.test.ts",
    "pretypecheck": "npm run fixtures:check",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "expo": "57.0.4",
    "expo-sqlite": "57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "@types/react": "19.2.14",
    "expo-doctor": "1.20.0",
    "tsx": "4.20.5",
    "typescript": "6.0.3"
  }
}
